    lt_params = url_param_get_tab( url ).
    DATA lv_val TYPE string.
    lv_val = c_trim_lower( val ).
    DATA temp1102 TYPE string.
    CLEAR temp1102.
    DATA temp1103 TYPE z2ui5_cl_a2ui5_context=>ty_s_name_value.
