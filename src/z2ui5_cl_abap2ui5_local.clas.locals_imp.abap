  METHOD rtti_create_sel_tab_type.

    DATA lt_comp TYPE cl_abap_structdescr=>component_table.

    FIELD-SYMBOLS <tab> TYPE ANY TABLE.
    ASSIGN ir_tab->* TO <tab>.

    DATA temp1112 TYPE REF TO cl_abap_tabledescr.
    temp1112 ?= cl_abap_typedescr=>describe_by_data( <tab> ).
    DATA lo_table LIKE temp1112.
    lo_table = temp1112.
    TRY.
        DATA temp1113 TYPE REF TO cl_abap_structdescr.
        temp1113 ?= lo_table->get_table_line_type( ).
        DATA lo_struct LIKE temp1113.
        lo_struct = temp1113.
        lt_comp = lo_struct->get_components( ).
      CATCH cx_root.
        result-check_table_line = abap_true.
        DATA temp1114 TYPE REF TO cl_abap_elemdescr.
        temp1114 ?= lo_table->get_table_line_type( ).
        DATA lo_elem LIKE temp1114.
        lo_elem = temp1114.
        DATA temp1115 TYPE abap_componentdescr.
        CLEAR temp1115.
        temp1115-name = `TAB_LINE`.
        temp1115-type = lo_elem.
        INSERT temp1115 INTO TABLE lt_comp.
    ENDTRY.

    DATA temp1116 LIKE sy-subrc.
    READ TABLE lt_comp WITH KEY name = sel_field_name TRANSPORTING NO FIELDS.
    temp1116 = sy-subrc.
    IF add_sel_field = abap_true
        AND NOT temp1116 = 0.
      DATA lo_type_bool TYPE REF TO cl_abap_typedescr.
      lo_type_bool = cl_abap_typedescr=>describe_by_name( `ABAP_BOOL` ).
      DATA temp1117 TYPE abap_componentdescr.
      CLEAR temp1117.
      temp1117-name = sel_field_name.
      DATA temp52 TYPE REF TO cl_abap_datadescr.
      temp52 ?= lo_type_bool.
      temp1117-type = temp52.
      INSERT temp1117 INTO TABLE lt_comp.
    ENDIF.

    DATA lo_line_type TYPE REF TO cl_abap_structdescr.
    lo_line_type = cl_abap_structdescr=>create( lt_comp ).
    result-tabledescr = cl_abap_tabledescr=>create( lo_line_type ).

  ENDMETHOD.

