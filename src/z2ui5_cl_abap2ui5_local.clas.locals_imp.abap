  METHOD boolean_abap_2_json.

    IF boolean_check_by_data( val ) IS NOT INITIAL.
      DATA temp808 TYPE string.
      IF val = abap_true.
        temp808 = `true`.
      ELSE.
        temp808 = `false`.
