CLASS z2ui5_cl_http_handler IMPLEMENTATION.

  METHOD main.

    ms_req = mo_server->get_req_info( ).

    CASE ms_req-method.
      WHEN `HEAD`.
        mo_server->set_session_stateful( 0 ).
        RETURN.
      WHEN OTHERS.
        ms_res = _main( ms_req ).
    ENDCASE.

    set_response( ).

  ENDMETHOD.

  METHOD factory.

    IF server IS BOUND.
      CREATE OBJECT result.
      result->mo_server = z2ui5_cl_a2ui5_http=>factory( server ).
    ELSEIF req IS BOUND AND res IS BOUND.
      result = factory_cloud( req = req
                              res = res ).
    ELSE.
      RAISE EXCEPTION TYPE z2ui5_cx_a2ui5_error
        EXPORTING val = `EMPTY_HTTP_HANDLER_CALL_ERROR`.
    ENDIF.

  ENDMETHOD.

  METHOD factory_cloud.

    CREATE OBJECT result.
    result->mo_server = z2ui5_cl_a2ui5_http=>factory_cloud( req = req
                                                           res  = res ).

  ENDMETHOD.

  METHOD _http_get.

    DATA temp988 TYPE z2ui5_if_types=>ty_s_http_config.
    CLEAR temp988.
    DATA ls_config LIKE temp988.
    ls_config = temp988.
    z2ui5_cl_exit=>get_instance( )->set_config_http_get( CHANGING cs_config = ls_config ).

    IF ls_config-styles_css IS INITIAL.
      DATA lv_style_css TYPE string.
      lv_style_css = z2ui5_cl_app_style_css=>get( ).
    ELSE.
      lv_style_css = ls_config-styles_css.
    ENDIF.

    result-body = |<!DOCTYPE html>| && |\n| &&
               |<html lang="en">| && |\n| &&
               |<head>| && |\n| &&
                  |{ ls_config-content_security_policy }\n| &&
               |    <meta charset="UTF-8">| && |\n| &&
               |    <meta name="viewport" content="width=device-width, initial-scale=1.0">| && |\n| &&
               |    <meta http-equiv="X-UA-Compatible" content="IE=edge">| && |\n| &&
                |<title>{ ls_config-title }</title>\n| &&
                | <style>        html, body, body > div, #container, #container-uiarea \{\n| &&
                |            height: 100%;\n| &&
                |        \}</style> \n| &&
                |<script>| && |\n| &&
             |  function onInitComponent()\{| && |\n| &&
             |    sap.ui.require.preload(\{| && |\n| &&
             " The entries for all embedded frontend files come from the
             " generated preload mapping (see .github/app2abap/trans2abap.js),
             " so the list can never run out of sync with app/webapp.
             z2ui5_cl_app_preload=>get( styles_css = lv_style_css
                                        custom_js  = ls_config-custom_js ) &&
             |    \});| && |\n| &&
             |    sap.ui.require(["sap/ui/core/ComponentSupport"], function(ComponentSupport)\{| && |\n| &&
             |     window.z2ui5 = \{ checkLocal : true \}; ComponentSupport.run();| && |\n| &&
             |    \});| && |\n| &&
             |  \}| && |\n| &&
             |</script>| && |\n| &&
                |<script id="sap-ui-bootstrap" data-sap-ui-resourceroots='\{ "z2ui5": "./" \}' data-sap-ui-oninit="onInitComponent" | && |\n| &&
                 |data-sap-ui-compatVersion="edge" data-sap-ui-async="true" data-sap-ui-frameOptions="trusted" data-sap-ui-bindingSyntax="complex"| && |\n| &&
                 |data-sap-ui-theme="{ ls_config-theme }" src="{ ls_config-src }"|.

    DATA temp989 LIKE LINE OF ls_config-t_add_config.
    DATA lr_config LIKE REF TO temp989.
    LOOP AT ls_config-t_add_config REFERENCE INTO lr_config.
      result-body = |{ result-body } { lr_config->n }='{ lr_config->v }'|.
    ENDLOOP.

    result-body          = result-body &&
                 | ></script></head>| && |\n| &&
                 |<body class="sapUiBody sapUiSizeCompact" id="content">| && |\n| &&
                 |    <div data-sap-ui-component data-name="z2ui5" data-id="container" data-settings='\{"id" : "z2ui5"\}' data-handle-validation="true"></div>| && |\n| &&
                 | </body></html>|.

    result-status_code   = 200.
    result-status_reason = `success`.

  ENDMETHOD.

  METHOD run.

    DATA lo_handler TYPE REF TO z2ui5_cl_http_handler.
    lo_handler = factory( server = server
                                req    = req
                                res    = res ).

    lo_handler->main( ).

  ENDMETHOD.

  METHOD set_response.

    mo_server->set_cdata( ms_res-body ).

    DATA temp990 TYPE z2ui5_if_types=>ty_s_http_config.
    CLEAR temp990.
    DATA ls_config LIKE temp990.
    ls_config = temp990.
    z2ui5_cl_exit=>get_instance( )->set_config_http_get( CHANGING cs_config = ls_config ).

    DATA ls_header LIKE LINE OF ls_config-t_security_header.
    LOOP AT ls_config-t_security_header INTO ls_header.
      mo_server->set_header_field( n = ls_header-n
                                   v = ls_header-v ).
    ENDLOOP.

    mo_server->set_status( code   = ms_res-status_code
                           reason = ms_res-status_reason ).

    " transform cookie into header-based contextid handling
    DATA lv_contextid TYPE string.
    IF ms_res-s_stateful-switched = abap_true.
      mo_server->set_session_stateful( ms_res-s_stateful-active ).
      IF mo_server->get_header_field( `sap-contextid-accept` ) = `header`.
        lv_contextid = mo_server->get_response_cookie( `sap-contextid` ).
        IF lv_contextid IS NOT INITIAL.
          mo_server->delete_response_cookie( `sap-contextid` ).
          mo_server->set_header_field( n = `sap-contextid`
                                       v = lv_contextid ).
        ENDIF.
      ENDIF.
    ELSE.
      lv_contextid = mo_server->get_header_field( `sap-contextid` ).
      IF lv_contextid IS NOT INITIAL.
        mo_server->set_header_field( n = `sap-contextid`
                                     v = lv_contextid ).
      ENDIF.
    ENDIF.

  ENDMETHOD.

  METHOD _http_post.

    " exceptions are intentionally not caught here - they bubble up to the
    " single top-level catch in _main( ), which turns them into a 500 response
    IF so_sticky_handler IS NOT BOUND.
      DATA lo_post TYPE REF TO z2ui5_cl_core_handler.
      CREATE OBJECT lo_post TYPE z2ui5_cl_core_handler EXPORTING VAL = is_req-body.
    ELSE.
      lo_post = so_sticky_handler.
      lo_post->mv_request_json = is_req-body.
    ENDIF.

    result = lo_post->main( ).

    TRY.
        DATA temp991 TYPE REF TO z2ui5_if_app.
        temp991 ?= lo_post->mo_action->mo_app->mo_app.
        DATA li_app LIKE temp991.
        li_app = temp991.
        IF li_app->check_sticky = abap_true.
          so_sticky_handler = lo_post.
        ELSE.
          CLEAR so_sticky_handler.
        ENDIF.
      CATCH cx_root.
        CLEAR so_sticky_handler.
    ENDTRY.

  ENDMETHOD.

  METHOD _main.

    " Single top-level catch for the whole request. The framework may raise
    " anywhere (e.g. a wrong app name in the URL -> CREATE OBJECT of an unknown
    " class in factory_first_start); any unhandled exception is turned into a
    " 500 whose body carries the exception text, so the frontend shows the real
    " reason instead of the SAP ICF 500 page, which suppresses that text.
    TRY.
        z2ui5_cl_exit=>init_context( is_req ).

        CASE is_req-method.
          WHEN `GET`.
            result = _http_get( ).
          WHEN `POST`.
            result = _http_post( is_req ).
        ENDCASE.

        DATA lx TYPE REF TO cx_root.
      CATCH cx_root INTO lx.
        CLEAR result.
        result-body = lx->get_text( ).
        result-status_code = 500.
        result-status_reason = `Internal Server Error`.
    ENDTRY.

  ENDMETHOD.

  METHOD get_request.

    DATA lo_handler TYPE REF TO z2ui5_cl_http_handler.
    lo_handler = factory( server = server
                                req    = req
                                res    = res ).

    result-body   = lo_handler->mo_server->get_cdata( ).
    result-method = lo_handler->mo_server->get_method( ).

  ENDMETHOD.

ENDCLASS.

CLASS z2ui5_cl_exit IMPLEMENTATION.

  METHOD get_instance.

    IF gi_me IS BOUND.
      ri_exit = gi_me.
      RETURN.
    ENDIF.

    DATA lv_class_name TYPE string.
    lv_class_name = get_user_exit_class( ).

    IF lv_class_name IS NOT INITIAL.
      TRY.
          CREATE OBJECT gi_user_exit TYPE (lv_class_name).
        CATCH cx_root ##NO_HANDLER.
      ENDTRY.
    ENDIF.

    CREATE OBJECT gi_me TYPE z2ui5_cl_exit.
    ri_exit = gi_me.

  ENDMETHOD.

  METHOD get_user_exit_class.

    TRY.
        DATA exit_classes TYPE z2ui5_cl_a2ui5_context=>ty_t_classes.
        exit_classes = z2ui5_cl_a2ui5_context=>rtti_get_classes_impl_intf( `Z2UI5_IF_EXIT` ).
        DELETE exit_classes WHERE classname = `Z2UI5_CL_EXIT`.

        DATA temp992 TYPE string.
        CLEAR temp992.
        DATA temp993 TYPE z2ui5_cl_a2ui5_context=>ty_s_class_descr.
        READ TABLE exit_classes INTO temp993 INDEX 1.
        IF sy-subrc = 0.
          temp992 = temp993-classname.
        ENDIF.
        r_class_name = temp992.
      CATCH cx_root ##NO_HANDLER.
    ENDTRY.

  ENDMETHOD.

  METHOD z2ui5_if_exit~set_config_http_get.

    cs_config-title = `abap2UI5`.
    cs_config-theme = `sap_horizon`.

    cs_config-src = `https://sdk.openui5.org/resources/sap-ui-cachebuster/sap-ui-core.js`.

    " 'unsafe-eval' is required by the OpenUI5 1.71 ui5loader (it evaluates
    " module source as a string); without it the 1.71 bootstrap fails with a
    " CSP EvalError. Modern UI5 does not use eval, so keeping it here only
    " affects older releases, and 'unsafe-inline' is already allowed so the
    " delta is marginal. Apps pinning a modern UI5 can drop it via their exit.
    cs_config-content_security_policy =
      |<meta http-equiv="Content-Security-Policy" | &&
      |content="default-src 'self' 'unsafe-inline' 'unsafe-eval' data: | &&
      |ui5.sap.com *.ui5.sap.com | &&
      |sapui5.hana.ondemand.com *.sapui5.hana.ondemand.com | &&
      |openui5.hana.ondemand.com *.openui5.hana.ondemand.com | &&
      |sdk.openui5.org *.sdk.openui5.org | &&
      |cdn.jsdelivr.net *.cdn.jsdelivr.net | &&
      |cdnjs.cloudflare.com *.cdnjs.cloudflare.com schemas *.schemas; | &&
      |connect-src 'self' | &&
      |  ui5.sap.com *.ui5.sap.com | &&
      |  sapui5.hana.ondemand.com *.sapui5.hana.ondemand.com | &&
      |  openui5.hana.ondemand.com *.openui5.hana.ondemand.com | &&
      |  sdk.openui5.org *.sdk.openui5.org | &&
      |  cdn.jsdelivr.net *.cdn.jsdelivr.net | &&
      |  cdnjs.cloudflare.com *.cdnjs.cloudflare.com; | &&
      |worker-src 'self' blob:; "/>|.

    DATA temp994 TYPE z2ui5_if_types=>ty_t_name_value.
    CLEAR temp994.
    DATA temp995 LIKE LINE OF temp994.
    temp995-n = `cache-control`.
    temp995-v = `no-cache, no-store, must-revalidate`.
    INSERT temp995 INTO TABLE temp994.
    temp995-n = `Pragma`.
    temp995-v = `no-cache`.
    INSERT temp995 INTO TABLE temp994.
    temp995-n = `Expires`.
    temp995-v = `0`.
    INSERT temp995 INTO TABLE temp994.
    temp995-n = `X-Content-Type-Options`.
    temp995-v = `nosniff`.
    INSERT temp995 INTO TABLE temp994.
    temp995-n = `X-Frame-Options`.
    temp995-v = `SAMEORIGIN`.
    INSERT temp995 INTO TABLE temp994.
    temp995-n = `Referrer-Policy`.
    temp995-v = `strict-origin-when-cross-origin`.
    INSERT temp995 INTO TABLE temp994.
    temp995-n = `Permissions-Policy`.
    temp995-v = `geolocation=(self), microphone=(self), camera=(self), payment=(), usb=()`.
    INSERT temp995 INTO TABLE temp994.
    cs_config-t_security_header = temp994.

    IF gi_user_exit IS BOUND.
      gi_user_exit->set_config_http_get( EXPORTING is_context = context
                                         CHANGING  cs_config  = cs_config ).
    ENDIF.

  ENDMETHOD.

  METHOD z2ui5_if_exit~set_config_http_post.

    CONSTANTS lc_default_exp_time_in_hours TYPE i VALUE 4.

    cs_config-draft_exp_time_in_hours = lc_default_exp_time_in_hours.

    IF gi_user_exit IS BOUND.
      gi_user_exit->set_config_http_post( EXPORTING is_context = context
                                          CHANGING  cs_config  = cs_config ).
    ENDIF.

    IF cs_config-draft_exp_time_in_hours <= 0.
      cs_config-draft_exp_time_in_hours = lc_default_exp_time_in_hours.
    ENDIF.

  ENDMETHOD.

  METHOD init_context.

    MOVE-CORRESPONDING http_info TO context.
    DATA temp996 TYPE z2ui5_if_types=>ty_s_http_context-app_start.
    CLEAR temp996.
    DATA temp997 TYPE z2ui5_cl_a2ui5_context=>ty_s_name_value.
    READ TABLE http_info-t_params INTO temp997 WITH KEY n = `app_start`.
    IF sy-subrc = 0.
      temp996 = temp997-v.
    ENDIF.
    context-app_start = temp996.

  ENDMETHOD.

ENDCLASS.

CLASS z2ui5_cl_core_srv_model IMPLEMENTATION.

  METHOD main_json_to_attri.

    DATA temp998 LIKE LINE OF mt_attri->*.
    DATA lr_attri LIKE REF TO temp998.
    LOOP AT mt_attri->* REFERENCE INTO lr_attri
         WHERE bind = abap_true.                        "#EC CI_SORTSEQ
      TRY.

          DATA lo_val_front TYPE REF TO z2ui5_if_ajson.
          lo_val_front = model->slice( lr_attri->name_client ).
          IF lo_val_front IS NOT BOUND.
            CONTINUE.
          ENDIF.

          IF lo_val_front->exists( `/__delta` ) = abap_true.
            delta_apply_to_table( io_val_front = lo_val_front
                                  iv_name      = lr_attri->name ).
            CONTINUE.
          ENDIF.

          IF lr_attri->custom_mapper_back IS BOUND.
            lo_val_front = lo_val_front->map( lr_attri->custom_mapper_back ).
          ENDIF.

          IF lr_attri->custom_filter_back IS BOUND.
            lo_val_front = lo_val_front->filter( lr_attri->custom_filter_back ).
          ENDIF.

          TRY.
              DATA lr_ref TYPE REF TO data.
              lr_ref = attri_get_val_ref( lr_attri->name ).
            CATCH cx_root.
              CONTINUE.
          ENDTRY.

          FIELD-SYMBOLS <val> TYPE data.
          ASSIGN lr_ref->* TO <val>.

          lo_val_front->to_abap( EXPORTING iv_corresponding = abap_true
                                 IMPORTING ev_container     = <val> ).

          DATA x TYPE REF TO cx_root.
        CATCH cx_root INTO x.
          RAISE EXCEPTION TYPE z2ui5_cx_a2ui5_error
            EXPORTING
              val = |JSON_PARSING_ERROR: { x->get_text( ) }|.
      ENDTRY.
    ENDLOOP.

  ENDMETHOD.

  METHOD main_json_stringify.
    TRY.

        DATA temp999 TYPE REF TO z2ui5_if_ajson.
        temp999 ?= z2ui5_cl_ajson=>create_empty( ).
        DATA ajson_result LIKE temp999.
        ajson_result = temp999.
        DATA temp1000 TYPE REF TO z2ui5_if_ajson.
        temp1000 ?= z2ui5_cl_ajson=>create_empty( ii_custom_mapping = z2ui5_cl_ajson_mapping=>create_upper_case( ) ).
        DATA ajson_default LIKE temp1000.
        ajson_default = temp1000.

        TYPES: BEGIN OF ty_s_mapper_cache,
                 mapper TYPE REF TO z2ui5_if_ajson_mapping,
                 ajson  TYPE REF TO z2ui5_if_ajson,
               END OF ty_s_mapper_cache.
        TYPES temp33 TYPE STANDARD TABLE OF ty_s_mapper_cache WITH DEFAULT KEY.
DATA lt_mapper_cache TYPE temp33.

        DATA temp1001 LIKE LINE OF mt_attri->*.
        DATA lr_attri LIKE REF TO temp1001.
        LOOP AT mt_attri->* REFERENCE INTO lr_attri "#EC CI_SORTSEQ
             WHERE bind = abap_true
                   AND type_kind <> z2ui5_cl_a2ui5_context=>cv_typedescr_typekind_dref
                   AND type_kind <> z2ui5_cl_a2ui5_context=>cv_typedescr_typekind_oref.

          IF lr_attri->custom_mapper IS BOUND.
            DATA lr_mapper_cache TYPE REF TO ty_s_mapper_cache.
            READ TABLE lt_mapper_cache REFERENCE INTO lr_mapper_cache
                 WITH KEY mapper = lr_attri->custom_mapper. "#EC CI_SORTSEQ
            IF sy-subrc = 0.
              DATA ajson LIKE lr_mapper_cache->ajson.
              ajson = lr_mapper_cache->ajson.
            ELSE.
              DATA temp1002 TYPE REF TO z2ui5_if_ajson.
              temp1002 ?= z2ui5_cl_ajson=>create_empty( ii_custom_mapping = lr_attri->custom_mapper ).
              ajson = temp1002.
              DATA temp1003 TYPE ty_s_mapper_cache.
              CLEAR temp1003.
              temp1003-mapper = lr_attri->custom_mapper.
              temp1003-ajson = ajson.
              INSERT temp1003 INTO TABLE lt_mapper_cache.
            ENDIF.
          ELSE.
            ajson = ajson_default.
          ENDIF.

          TRY.
              DATA lr_ref TYPE REF TO data.
              lr_ref = attri_get_val_ref( lr_attri->name ).
            CATCH cx_root.
              CONTINUE.
          ENDTRY.

          FIELD-SYMBOLS <val> TYPE data.
          ASSIGN lr_ref->* TO <val>.

          ajson->set( iv_ignore_empty = abap_false
                      iv_path         = `/`
                      iv_val          = <val> ).

          IF lr_attri->custom_filter IS BOUND.
            ajson = ajson->filter( lr_attri->custom_filter ).
          ENDIF.

          ajson_result->set( iv_path = lr_attri->name_client
                             iv_val  = ajson ).
        ENDLOOP.

        result = ajson_result->stringify( ).
        IF result IS INITIAL.
          result = `{}`.
        ENDIF.

        DATA x TYPE REF TO cx_root.
      CATCH cx_root INTO x.
        RAISE EXCEPTION TYPE z2ui5_cx_a2ui5_error
          EXPORTING
            val = x.
    ENDTRY.
  ENDMETHOD.

  METHOD main_attri_db_load.

    main_attri_db_load_resolve( ).

    DATA lt_child_idx TYPE ty_t_child_idx.
    DATA temp1004 LIKE LINE OF mt_attri->*.
    DATA lr_pre LIKE REF TO temp1004.
    LOOP AT mt_attri->* REFERENCE INTO lr_pre     "#EC CI_SORTSEQ
         WHERE name_parent IS NOT INITIAL.
      DATA temp1005 TYPE z2ui5_cl_core_srv_model=>ty_s_child_idx.
      CLEAR temp1005.
      temp1005-name_parent = lr_pre->name_parent.
      temp1005-name = lr_pre->name.
      INSERT temp1005 INTO TABLE lt_child_idx.
    ENDLOOP.

    DATA lr_child_idx LIKE REF TO lt_child_idx.
    GET REFERENCE OF lt_child_idx INTO lr_child_idx.
    DATA temp1006 LIKE LINE OF mt_attri->*.
    DATA lr_attri LIKE REF TO temp1006.
    LOOP AT mt_attri->* REFERENCE INTO lr_attri   "#EC CI_SORTSEQ
         WHERE name_ref IS NOT INITIAL.
      CASE lr_attri->type_kind.
        WHEN z2ui5_cl_a2ui5_context=>cv_typedescr_typekind_table.
          main_attri_db_load_table( lr_attri ).
        WHEN z2ui5_cl_a2ui5_context=>cv_typedescr_typekind_dref.
          main_attri_db_load_dref( ir_attri     = lr_attri
                                   ir_child_idx = lr_child_idx ).
      ENDCASE.
    ENDLOOP.

  ENDMETHOD.

  METHOD main_attri_db_load_resolve.

    DATA temp1007 LIKE LINE OF mt_attri->*.
    DATA lr_attri LIKE REF TO temp1007.
    LOOP AT mt_attri->* REFERENCE INTO lr_attri   "#EC CI_SORTSEQ
         WHERE name_ref IS INITIAL.
      TRY.
          DATA lr_ref TYPE REF TO data.
          lr_ref = attri_get_val_ref( lr_attri->name ).
          lr_attri->o_typedescr = z2ui5_cl_a2ui5_context=>rtti_get_typedescr_by_data_ref( lr_ref ).
          IF lr_attri->srtti_data IS NOT INITIAL.
            FIELD-SYMBOLS <val> TYPE data.
            ASSIGN lr_ref->* TO <val>.
            <val> = z2ui5_cl_a2ui5_context=>xml_srtti_parse( lr_attri->srtti_data ).
            CLEAR lr_attri->srtti_data.
          ENDIF.
        CATCH cx_root ##NO_HANDLER.
      ENDTRY.
    ENDLOOP.

  ENDMETHOD.

  METHOD main_attri_db_load_table.

    DATA lr_ref_source TYPE REF TO data.
    lr_ref_source = attri_get_val_ref( ir_attri->name_ref ).
    ir_attri->o_typedescr = z2ui5_cl_a2ui5_context=>rtti_get_typedescr_by_data_ref( lr_ref_source ).

    DATA lr_attri_parent TYPE REF TO z2ui5_if_core_types=>ty_s_attri.
    READ TABLE mt_attri->* REFERENCE INTO lr_attri_parent
         WITH KEY name = ir_attri->name_parent.
    IF sy-subrc <> 0.
      RETURN.
    ENDIF.

    DATA lv_parent_path TYPE string.
    lv_parent_path = |MO_APP->{ lr_attri_parent->name }|.
    FIELD-SYMBOLS <parent_ref> TYPE any.
    ASSIGN (lv_parent_path) TO <parent_ref>.
    IF sy-subrc <> 0.
      RETURN.
    ENDIF.

    FIELD-SYMBOLS <source_value> TYPE data.
    ASSIGN lr_ref_source->* TO <source_value>.
    GET REFERENCE OF <source_value> INTO <parent_ref>.

    DATA lr_ref_parent TYPE REF TO data.
GET REFERENCE OF <parent_ref> INTO lr_ref_parent.
    lr_attri_parent->o_typedescr = z2ui5_cl_a2ui5_context=>rtti_get_typedescr_by_data_ref( lr_ref_parent ).

  ENDMETHOD.

  METHOD main_attri_db_load_dref.

    DATA lv_source_path TYPE string.
    lv_source_path = |MO_APP->{ ir_attri->name_ref }|.
    FIELD-SYMBOLS <source_ref> TYPE any.
    ASSIGN (lv_source_path) TO <source_ref>.
    IF sy-subrc <> 0.
      RETURN.
    ENDIF.

    DATA lv_target_path TYPE string.
    lv_target_path = |MO_APP->{ ir_attri->name }|.
    FIELD-SYMBOLS <parent_ref> TYPE any.
    ASSIGN (lv_target_path) TO <parent_ref>.
    IF sy-subrc <> 0.
      RETURN.
    ENDIF.
    GET REFERENCE OF <source_ref> INTO <parent_ref>.
    ir_attri->o_typedescr = z2ui5_cl_a2ui5_context=>rtti_get_typedescr_by_data_ref( <parent_ref> ).

    DATA temp1008 LIKE LINE OF ir_child_idx->*.
    DATA lr_child_idx LIKE REF TO temp1008.
    LOOP AT ir_child_idx->* REFERENCE INTO lr_child_idx
         WHERE name_parent = ir_attri->name.
      DATA lr_child TYPE REF TO z2ui5_if_core_types=>ty_s_attri.
      READ TABLE mt_attri->* REFERENCE INTO lr_child
           WITH KEY name = lr_child_idx->name.
      IF sy-subrc <> 0.
        CONTINUE.
      ENDIF.
      DATA lr_child_ref TYPE REF TO data.
      lr_child_ref = attri_get_val_ref( lr_child->name ).
      lr_child->o_typedescr = z2ui5_cl_a2ui5_context=>rtti_get_typedescr_by_data_ref( lr_child_ref ).
    ENDLOOP.

  ENDMETHOD.

  METHOD main_attri_db_save_srtti.

    dissolve( ).

    DATA temp1009 LIKE LINE OF mt_attri->*.
    DATA lr_attri LIKE REF TO temp1009.
    LOOP AT mt_attri->* REFERENCE INTO lr_attri   "#EC CI_SORTSEQ
         WHERE name_ref  IS INITIAL
               AND type_kind  = z2ui5_cl_a2ui5_context=>cv_typedescr_typekind_dref.

      DATA lv_path_ref TYPE string.
      lv_path_ref = |MO_APP->{ lr_attri->name }|.
      FIELD-SYMBOLS <ref> TYPE any.
      ASSIGN (lv_path_ref) TO <ref>.
      IF sy-subrc <> 0.
        CONTINUE.
      ENDIF.
      DATA lv_path_deref TYPE string.
      lv_path_deref = |MO_APP->{ lr_attri->name }->*|.
      FIELD-SYMBOLS <val_deref> TYPE any.
      ASSIGN (lv_path_deref) TO <val_deref>.
      IF sy-subrc <> 0.
        CONTINUE.
      ENDIF.
      DATA lo_descr TYPE REF TO cl_abap_typedescr.
      lo_descr = z2ui5_cl_a2ui5_context=>rtti_get_typedescr_by_data( <val_deref> ).

      CASE lo_descr->type_kind.

        WHEN z2ui5_cl_a2ui5_context=>cv_typedescr_typekind_table.

          DATA temp1010 LIKE LINE OF mt_attri->*.
          DATA lr_attri_child LIKE REF TO temp1010.
          LOOP AT mt_attri->* REFERENCE INTO lr_attri_child "#EC CI_SORTSEQ
               WHERE name_ref    IS INITIAL
                     AND type_kind    = z2ui5_cl_a2ui5_context=>cv_typedescr_typekind_table
                     AND name_parent  = lr_attri->name.

            DATA lv_path_child TYPE string.
            lv_path_child = |MO_APP->{ lr_attri_child->name }|.
            FIELD-SYMBOLS <val_ref> TYPE any.
            ASSIGN (lv_path_child) TO <val_ref>.
            IF sy-subrc <> 0.
              CONTINUE.
            ENDIF.
            lr_attri->srtti_data = z2ui5_cl_a2ui5_context=>xml_srtti_stringify( <val_ref> ).
            CLEAR <val_ref>.
            CLEAR <val_deref>.
            CLEAR <ref>.
            EXIT.
          ENDLOOP.

        WHEN z2ui5_cl_a2ui5_context=>cv_typedescr_typekind_struct1 OR z2ui5_cl_a2ui5_context=>cv_typedescr_typekind_struct2.
          lr_attri->srtti_data = z2ui5_cl_a2ui5_context=>xml_srtti_stringify( <val_deref> ).

      ENDCASE.

    ENDLOOP.

    DATA temp1011 LIKE LINE OF mt_attri->*.
    DATA lr_attri2 LIKE REF TO temp1011.
    LOOP AT mt_attri->* REFERENCE INTO lr_attri2  "#EC CI_SORTSEQ
         WHERE type_kind = z2ui5_cl_a2ui5_context=>cv_typedescr_typekind_dref.

      DATA lv_path_dref TYPE string.
      lv_path_dref = |MO_APP->{ lr_attri2->name }|.
      FIELD-SYMBOLS <dref> TYPE any.
      ASSIGN (lv_path_dref) TO <dref>.
      IF sy-subrc <> 0.
        CONTINUE.
      ENDIF.
      CLEAR <dref>.

      IF lr_attri2->name_ref IS NOT INITIAL.
        CONTINUE.
      ENDIF.

      DATA lv_path_dref_deref TYPE string.
      lv_path_dref_deref = |MO_APP->{ lr_attri2->name }->*|.
      FIELD-SYMBOLS <dref_deref> TYPE any.
      ASSIGN (lv_path_dref_deref) TO <dref_deref>.
      IF sy-subrc <> 0.
        CONTINUE.
      ENDIF.
      CLEAR <dref_deref>.
    ENDLOOP.

  ENDMETHOD.

  METHOD main_attri_search.

    result = attri_search( val ).
    IF result IS BOUND.
      RETURN.
    ENDIF.

    dissolve( ).
    result = attri_search( val ).
    IF result IS BOUND.
      RETURN.
    ENDIF.

    main_attri_refresh( ).
    result = attri_search( val ).
    IF result IS BOUND.
      RETURN.
    ENDIF.

    RAISE EXCEPTION TYPE z2ui5_cx_a2ui5_error
      EXPORTING
        val = `BINDING_ERROR - No class attribute for binding found - Please check if the bound values are public attributes of your class`.

  ENDMETHOD.

  METHOD attri_get_val_ref.

    FIELD-SYMBOLS <attri> TYPE any.

    IF iv_path IS INITIAL.
      ASSIGN mo_app TO <attri>.
    ELSE.
      DATA lv_name TYPE string.
      lv_name = |MO_APP->{ iv_path }|.
      ASSIGN (lv_name) TO <attri>.
    ENDIF.

    IF <attri> IS NOT ASSIGNED.
      RAISE EXCEPTION TYPE z2ui5_cx_a2ui5_error
        EXPORTING
          val = `ATTRI_GET_VAL_REF_ERROR`.
    ENDIF.

    GET REFERENCE OF <attri> INTO result.
    IF result IS NOT BOUND.
      RAISE EXCEPTION TYPE z2ui5_cx_a2ui5_error
        EXPORTING
          val = `ATTRI_GET_VAL_REF_ERROR`.
    ENDIF.

  ENDMETHOD.

  METHOD constructor.

    mt_attri = attri.
    mo_app = app.

  ENDMETHOD.

  METHOD attri_search.

    DATA lo_datadescr TYPE REF TO cl_abap_typedescr.
    lo_datadescr = z2ui5_cl_a2ui5_context=>rtti_get_typedescr_by_data_ref( val ).

    IF lo_datadescr->type_kind = z2ui5_cl_a2ui5_context=>cv_typedescr_typekind_dref
        OR lo_datadescr->type_kind = z2ui5_cl_a2ui5_context=>cv_typedescr_typekind_oref.
      RAISE EXCEPTION TYPE z2ui5_cx_a2ui5_error
        EXPORTING
          val = `NO DATA REFERENCES FOR BINDING ALLOWED: DEREFERENCE YOUR DATA FIRST`.
    ENDIF.

    DATA temp1012 LIKE LINE OF mt_attri->*.
    DATA lr_attri LIKE REF TO temp1012.
    LOOP AT mt_attri->* REFERENCE INTO lr_attri   "#EC CI_SORTSEQ
         WHERE name_ref  IS INITIAL
               AND type_kind  = lo_datadescr->type_kind
               AND kind       = lo_datadescr->kind.

      " compare by name - descriptor instances are not stable in the
      " abaplint transpiler runtime; the data reference check below is
      " the definitive match, this is only a prefilter. Generated names
      " of anonymous types (containing %) are not comparable either
      DATA lv_name_attri LIKE lr_attri->o_typedescr->absolute_name.
      lv_name_attri = lr_attri->o_typedescr->absolute_name.
      DATA lv_name_val LIKE lo_datadescr->absolute_name.
      lv_name_val = lo_datadescr->absolute_name.
      IF lv_name_attri <> lv_name_val
          AND lv_name_attri NS `%`
          AND lv_name_val NS `%`.
        CONTINUE.
      ENDIF.

      TRY.
          DATA lr_ref TYPE REF TO data.
          lr_ref = attri_get_val_ref( lr_attri->name ).
        CATCH cx_root.
          CONTINUE.
      ENDTRY.

      IF lr_ref = val.
        result = lr_attri.
        RETURN.
      ENDIF.
    ENDLOOP.

  ENDMETHOD.

  METHOD attri_create_new.

    DATA lo_descr TYPE REF TO cl_abap_typedescr.
    lo_descr = z2ui5_cl_a2ui5_context=>rtti_get_typedescr_by_data_ref( attri_get_val_ref( name ) ).
    DATA temp1013 TYPE z2ui5_if_core_types=>ty_s_attri.
    CLEAR temp1013.
    temp1013-name = name.
    temp1013-o_typedescr = lo_descr.
    temp1013-type_kind = lo_descr->type_kind.
    temp1013-kind = lo_descr->kind.
    result = temp1013.

  ENDMETHOD.

  METHOD diss_dref.

    DATA lr_ref_tmp TYPE REF TO data.
    lr_ref_tmp = attri_get_val_ref( ir_attri->name ).

    IF z2ui5_cl_a2ui5_context=>check_unassign_initial( lr_ref_tmp ) IS NOT INITIAL.
      RETURN.
    ENDIF.

    DATA lr_ref TYPE REF TO data.
    lr_ref = z2ui5_cl_a2ui5_context=>unassign_data( lr_ref_tmp ).
    IF lr_ref IS INITIAL.
      RETURN.
    ENDIF.

    DATA temp1014 TYPE z2ui5_if_core_types=>ty_s_attri.
    CLEAR temp1014.
    DATA ls_attri2 LIKE temp1014.
    ls_attri2 = temp1014.
    ls_attri2-o_typedescr = z2ui5_cl_a2ui5_context=>rtti_get_typedescr_by_data_ref( lr_ref ).

    CASE ls_attri2-o_typedescr->kind.

      WHEN z2ui5_cl_a2ui5_context=>cv_typedescr_kind_struct.
        DATA lt_attri TYPE z2ui5_if_core_types=>ty_t_attri.
        lt_attri = diss_struc( ir_attri ).
        INSERT LINES OF lt_attri INTO TABLE result.

      WHEN OTHERS.

        ls_attri2-name        = |{ ir_attri->name }->*|.
        ls_attri2-name_parent = ir_attri->name.
        ls_attri2-type_kind   = ls_attri2-o_typedescr->type_kind.
        ls_attri2-kind        = ls_attri2-o_typedescr->kind.
        INSERT ls_attri2 INTO TABLE result.

    ENDCASE.

  ENDMETHOD.

  METHOD diss_oref.

    DATA lr_val TYPE REF TO data.
    lr_val = attri_get_val_ref( ir_attri->name ).

    IF z2ui5_cl_a2ui5_context=>check_unassign_initial( lr_val ) IS NOT INITIAL.
      RETURN.
    ENDIF.

    DATA lr_ref TYPE REF TO object.
    lr_ref = z2ui5_cl_a2ui5_context=>unassign_object( lr_val ).
    DATA lt_attri TYPE abap_attrdescr_tab.
    lt_attri = z2ui5_cl_a2ui5_context=>rtti_get_t_attri_by_oref( lr_ref ).

    DATA temp1015 TYPE string.
    IF ir_attri->name IS NOT INITIAL.
      temp1015 = |{ ir_attri->name }->|.
    ELSE.
      CLEAR temp1015.
    ENDIF.
    DATA lv_prefix LIKE temp1015.
    lv_prefix = temp1015.

    DATA temp1016 LIKE LINE OF lt_attri.
    DATA lr_attri LIKE REF TO temp1016.
    LOOP AT lt_attri REFERENCE INTO lr_attri
         WHERE visibility   = z2ui5_cl_a2ui5_context=>cv_objectdescr_public
               AND is_interface = abap_false
               AND is_class     = abap_false
               AND is_constant  = abap_false.
      TRY.
          DATA ls_new TYPE z2ui5_if_core_types=>ty_s_attri.
          ls_new = attri_create_new( lv_prefix && lr_attri->name ).
          ls_new-name_parent = ir_attri->name.
          INSERT ls_new INTO TABLE result.

        CATCH cx_root ##NO_HANDLER.
      ENDTRY.
    ENDLOOP.

  ENDMETHOD.

  METHOD diss_struc.

    DATA lr_val TYPE REF TO data.
    lr_val = attri_get_val_ref( ir_attri->name ).

    IF ir_attri->o_typedescr->kind = z2ui5_cl_a2ui5_context=>cv_typedescr_kind_ref.
      DATA lv_name TYPE string.
      lv_name = |{ ir_attri->name }->|.
      DATA lr_ref TYPE REF TO data.
      lr_ref = z2ui5_cl_a2ui5_context=>unassign_data( lr_val ).
    ELSE.
      lv_name = |{ ir_attri->name }-|.
      lr_ref = lr_val.
    ENDIF.

    IF lr_ref IS BOUND.
      DATA lt_attri TYPE abap_component_tab.
      lt_attri = z2ui5_cl_a2ui5_context=>rtti_get_t_attri_by_any( lr_ref ).

      DATA ls_attri LIKE LINE OF lt_attri.
      LOOP AT lt_attri INTO ls_attri.
        DATA ls_new TYPE z2ui5_if_core_types=>ty_s_attri.
        ls_new = attri_create_new( lv_name && ls_attri-name ).
        ls_new-name_parent = ir_attri->name.
        INSERT ls_new INTO TABLE result.
      ENDLOOP.
    ENDIF.
  ENDMETHOD.

  METHOD dissolve.

    DATA lv_depth TYPE i.

    DATA temp1017 LIKE sy-subrc.
    READ TABLE mt_attri->* WITH KEY check_dissolved = abap_false TRANSPORTING NO FIELDS.
    temp1017 = sy-subrc.
    WHILE temp1017 = 0 OR mt_attri->* IS INITIAL. "#EC CI_SORTSEQ

      lv_depth = lv_depth + 1.
      IF lv_depth >= max_dissolve_depth.
        RETURN.
      ENDIF.

      TRY.
          dissolve_run( ).
        CATCH cx_root.
          main_attri_refresh( ).
      ENDTRY.

    ENDWHILE.

    attri_update_entry_refs( ).

  ENDMETHOD.

  METHOD attri_update_entry_refs.

    " Declared once at method level: both CASE branches below fill and read
    " these, so an inline DATA(...) in only the first branch would read as if
    " they belonged to that branch alone.
    DATA lr_attri_ref     TYPE REF TO z2ui5_if_core_types=>ty_s_attri.
    DATA lr_attri_ref_ref TYPE REF TO data.

    DATA temp1018 LIKE LINE OF mt_attri->*.
    DATA lr_attri LIKE REF TO temp1018.
    LOOP AT mt_attri->* REFERENCE INTO lr_attri   "#EC CI_SORTSEQ
         WHERE check_dissolved  = abap_true
               AND name_ref        IS INITIAL.

      TRY.
          DATA lr_ref TYPE REF TO data.
          lr_ref = attri_get_val_ref( lr_attri->name ).
        CATCH cx_root.
          CONTINUE.
      ENDTRY.

      CASE lr_attri->type_kind.

        WHEN z2ui5_cl_a2ui5_context=>cv_typedescr_typekind_table.

          LOOP AT mt_attri->* REFERENCE INTO lr_attri_ref "#EC CI_SORTSEQ
               WHERE check_dissolved  = abap_true
                     AND name            <> lr_attri->name
                     AND name_ref        IS INITIAL
                     AND type_kind        = z2ui5_cl_a2ui5_context=>cv_typedescr_typekind_table.

            TRY.
                lr_attri_ref_ref = attri_get_val_ref( lr_attri_ref->name ).
              CATCH cx_root.
                CONTINUE.
            ENDTRY.

            IF lr_ref <> lr_attri_ref_ref.
              CONTINUE.
            ENDIF.

            lr_attri->name_ref = lr_attri_ref->name.
          ENDLOOP.

        WHEN z2ui5_cl_a2ui5_context=>cv_typedescr_typekind_dref.

          FIELD-SYMBOLS <ref> TYPE data.
          ASSIGN lr_ref->* TO <ref>.

          LOOP AT mt_attri->* REFERENCE INTO lr_attri_ref "#EC CI_SORTSEQ
               WHERE check_dissolved  = abap_true
                     AND name            <> lr_attri->name
                     AND name_ref        IS INITIAL
                     AND (    type_kind = z2ui5_cl_a2ui5_context=>cv_typedescr_typekind_struct1
                           OR type_kind = z2ui5_cl_a2ui5_context=>cv_typedescr_typekind_struct2 ).

            TRY.
                lr_attri_ref_ref = attri_get_val_ref( lr_attri_ref->name ).
              CATCH cx_root.
                CONTINUE.
            ENDTRY.

            IF <ref> <> lr_attri_ref_ref.
              CONTINUE.
            ENDIF.

            IF lr_attri->name_ref IS NOT INITIAL AND strlen( lr_attri->name_ref ) <= strlen( lr_attri_ref->name ).
              CONTINUE.
            ENDIF.

            lr_attri->name_ref = lr_attri_ref->name.
            attri_update_refs_children( lr_attri ).
          ENDLOOP.

      ENDCASE.

    ENDLOOP.

  ENDMETHOD.

  METHOD attri_update_refs_children.

    DATA temp1019 LIKE LINE OF mt_attri->*.
    DATA lr_attri_child LIKE REF TO temp1019.
    LOOP AT mt_attri->* REFERENCE INTO lr_attri_child "#EC CI_SORTSEQ
         WHERE name_parent = ir_attri->name.
      DATA lv_name TYPE string.
      lv_name = shift_left( val = lr_attri_child->name
                                  sub = |{ ir_attri->name }->| ).
      lr_attri_child->name_ref = |{ ir_attri->name_ref }-{ lv_name }|.
    ENDLOOP.

  ENDMETHOD.

  METHOD dissolve_run.

    IF mt_attri->* IS INITIAL.
      DATA temp1020 TYPE z2ui5_if_core_types=>ty_s_attri.
      CLEAR temp1020.
      DATA ls_attri LIKE temp1020.
      ls_attri = temp1020.
      DATA temp1021 LIKE REF TO ls_attri.
      GET REFERENCE OF ls_attri INTO temp1021.
DATA lt_init TYPE z2ui5_if_core_types=>ty_t_attri.
lt_init = diss_oref( temp1021 ).
      INSERT LINES OF lt_init INTO TABLE mt_attri->*.
    ENDIF.

    DATA temp1022 TYPE z2ui5_if_core_types=>ty_t_attri.
    CLEAR temp1022.
    DATA lt_attri_new LIKE temp1022.
    lt_attri_new = temp1022.

    DATA temp1023 LIKE LINE OF mt_attri->*.
    DATA lr_attri LIKE REF TO temp1023.
    LOOP AT mt_attri->* REFERENCE INTO lr_attri   "#EC CI_SORTSEQ
         WHERE check_dissolved = abap_false.

      lr_attri->check_dissolved = abap_true.

      IF lr_attri->o_typedescr IS NOT BOUND.
        DATA ls_entry TYPE z2ui5_if_core_types=>ty_s_attri.
        ls_entry = attri_create_new( lr_attri->name ).
        lr_attri->o_typedescr = ls_entry-o_typedescr.
      ENDIF.

      CASE lr_attri->o_typedescr->kind.

        WHEN z2ui5_cl_a2ui5_context=>cv_typedescr_kind_struct.
          DATA lt_attri_struc TYPE z2ui5_if_core_types=>ty_t_attri.
          lt_attri_struc = diss_struc( lr_attri ).
          INSERT LINES OF lt_attri_struc INTO TABLE lt_attri_new.

        WHEN z2ui5_cl_a2ui5_context=>cv_typedescr_kind_ref.

          CASE lr_attri->o_typedescr->type_kind.

            WHEN z2ui5_cl_a2ui5_context=>cv_typedescr_typekind_oref.
              DATA lt_attri_oref TYPE z2ui5_if_core_types=>ty_t_attri.
              lt_attri_oref = diss_oref( lr_attri ).
              INSERT LINES OF lt_attri_oref INTO TABLE lt_attri_new.
            WHEN z2ui5_cl_a2ui5_context=>cv_typedescr_typekind_dref.
              DATA lt_attri_dref TYPE z2ui5_if_core_types=>ty_t_attri.
              lt_attri_dref = diss_dref( lr_attri ).
              INSERT LINES OF lt_attri_dref INTO TABLE lt_attri_new.
            WHEN OTHERS.
              " an unexpected ref type_kind is left as a non-dissolvable leaf
              " (like the unknown-kind WHEN OTHERS below) - an ASSERT here
              " would raise the uncatchable ASSERTION_FAILED and defeat the
              " TRY/CATCH around dissolve_run, dumping the whole request
          ENDCASE.
        WHEN OTHERS.
      ENDCASE.

    ENDLOOP.

    INSERT LINES OF lt_attri_new INTO TABLE mt_attri->*.

  ENDMETHOD.

  METHOD main_attri_refresh.

    DATA lt_attri TYPE z2ui5_if_core_types=>ty_t_attri.
    lt_attri = mt_attri->*.
    DELETE lt_attri WHERE bind = abap_false.            "#EC CI_SORTSEQ
    CLEAR mt_attri->*.

    dissolve( ).

    DATA temp1024 LIKE LINE OF mt_attri->*.
    DATA lr_attri LIKE REF TO temp1024.
    LOOP AT mt_attri->* REFERENCE INTO lr_attri.
      DATA lr_old TYPE REF TO z2ui5_if_core_types=>ty_s_attri.
      READ TABLE lt_attri REFERENCE INTO lr_old WITH KEY name = lr_attri->name. "#EC CI_SORTSEQ
      IF sy-subrc = 0.
        lr_attri->bind        = lr_old->bind.
        lr_attri->name_client = lr_old->name_client.
      ENDIF.
    ENDLOOP.

  ENDMETHOD.

  METHOD delta_apply_to_table.

    TRY.
        DATA lr_ref_d TYPE REF TO data.
        lr_ref_d = attri_get_val_ref( iv_name ).
      CATCH cx_root.
        RETURN.
    ENDTRY.

    FIELD-SYMBOLS <delta_tab> TYPE STANDARD TABLE.
    ASSIGN lr_ref_d->* TO <delta_tab>.
    IF sy-subrc <> 0.
      RETURN.
    ENDIF.

    delta_apply_nodes( EXPORTING io_delta = io_val_front->slice( `/__delta` )
                       CHANGING  ct_tab   = <delta_tab> ).

  ENDMETHOD.

  METHOD delta_apply_nodes.

    DATA lt_idx TYPE string_table.
    lt_idx = io_delta->members( `/` ).
    DATA lv_idx_str LIKE LINE OF lt_idx.
    LOOP AT lt_idx INTO lv_idx_str.
      DATA lv_tabix TYPE i.
      TRY.
          " the delta key is a client-supplied row index; a garbled
          " (non-numeric) key must skip that row, not dump the request
          DATA temp1025 TYPE i.
          temp1025 = lv_idx_str.
          lv_tabix = temp1025 + 1.
        CATCH cx_root.
          CONTINUE.
      ENDTRY.
      FIELD-SYMBOLS <delta_row> TYPE any.
      READ TABLE ct_tab INDEX lv_tabix ASSIGNING <delta_row>.
      IF sy-subrc <> 0.
        CONTINUE.
      ENDIF.
      DATA lo_row_d TYPE REF TO z2ui5_if_ajson.
      lo_row_d = io_delta->slice( |/{ lv_idx_str }| ).
      DATA lt_fld TYPE string_table.
      lt_fld = lo_row_d->members( `/` ).
      DATA lv_fld LIKE LINE OF lt_fld.
      LOOP AT lt_fld INTO lv_fld.
        FIELD-SYMBOLS <comp> TYPE any.
        ASSIGN COMPONENT lv_fld OF STRUCTURE <delta_row> TO <comp>.
        IF sy-subrc <> 0.
          CONTINUE.
        ENDIF.
        DATA temp1026 TYPE REF TO data.
GET REFERENCE OF <comp> INTO temp1026.
delta_apply_field( io_row_d = lo_row_d
                           iv_path  = |/{ lv_fld }|
                           ir_comp  = temp1026 ).
      ENDLOOP.
    ENDLOOP.

  ENDMETHOD.

  METHOD delta_apply_field.

    FIELD-SYMBOLS <comp> TYPE any.
    ASSIGN ir_comp->* TO <comp>.

    TRY.
        CASE io_row_d->get_node_type( iv_path ).

          WHEN z2ui5_if_ajson_types=>node_type-boolean.
            <comp> = io_row_d->get_boolean( iv_path ).

          WHEN z2ui5_if_ajson_types=>node_type-object.
            " either a nested table delta (marked by __delta) or a
            " structure component shipped as a whole value
            DATA lo_sub TYPE REF TO z2ui5_if_ajson.
            lo_sub = io_row_d->slice( iv_path ).
            IF lo_sub->exists( `/__delta` ) = abap_true.
              FIELD-SYMBOLS <sub_tab> TYPE STANDARD TABLE.
              ASSIGN ir_comp->* TO <sub_tab>.
              IF sy-subrc = 0.
                delta_apply_nodes( EXPORTING io_delta = lo_sub->slice( `/__delta` )
                                   CHANGING  ct_tab   = <sub_tab> ).
              ENDIF.
            ELSE.
              lo_sub->to_abap( EXPORTING iv_corresponding = abap_true
                               IMPORTING ev_container     = <comp> ).
            ENDIF.

          WHEN z2ui5_if_ajson_types=>node_type-array.
            " a whole sub-table value replaced a nested delta on the client
            io_row_d->slice( iv_path )->to_abap( EXPORTING iv_corresponding = abap_true
                                                 IMPORTING ev_container     = <comp> ).

          WHEN OTHERS.
            " numbers intentionally go through get_string: the raw JSON text
            " converts losslessly into any numeric target type, while
            " get_number would round through a binary float first
            <comp> = io_row_d->get_string( iv_path ).
        ENDCASE.

      CATCH cx_root.
        " a single malformed cell (e.g. text sent into a numeric target)
        " must not discard every other edit in this batch - skip just it
        RETURN.
    ENDTRY.

  ENDMETHOD.

ENDCLASS.

CLASS z2ui5_cl_core_srv_event IMPLEMENTATION.

  METHOD get_event.

    result = |{ z2ui5_if_core_types=>cs_ui5-event_backend_function }(['{ val }'|.

    IF s_cnt-check_allow_multi_req = abap_true.
      result = |{ result },false,true|.
    ENDIF.

    result = |{ result }]{ get_t_arg( t_arg ) }|.

  ENDMETHOD.

  METHOD get_event_client.

    DATA temp1027 TYPE string.
    temp1027 = val.
    DATA lv_val LIKE temp1027.
    lv_val = temp1027.
    DATA lt_arg LIKE t_arg.
    lt_arg = t_arg.

    " NavContainer navigation reuses the generic cs_event-control_by_id call
    " so the frontend needs only the one generic dispatcher. Both the backend
    " follow-up action and the XML-bound client event (_event_client) are
    " formatted here, so this is the single place the *_nav_container_to events
    " are remapped to `<container>, <slot>, to, <target>`. The public
    " cs_event-*_nav_container_to constant values stay unchanged.
    DATA temp1028 TYPE string.
    CASE lv_val.
      WHEN z2ui5_if_client=>cs_event-nav_container_to.
        temp1028 = `MAIN`.
      WHEN z2ui5_if_client=>cs_event-nest_nav_container_to.
        temp1028 = `NEST`.
      WHEN z2ui5_if_client=>cs_event-nest2_nav_container_to.
        temp1028 = `NEST2`.
      WHEN z2ui5_if_client=>cs_event-popup_nav_container_to.
        temp1028 = `POPUP`.
      WHEN z2ui5_if_client=>cs_event-popover_nav_container_to.
        temp1028 = `POPOVER`.
      WHEN OTHERS.
        temp1028 = ``.
    ENDCASE.
    DATA lv_slot LIKE temp1028.
    lv_slot = temp1028.
    IF lv_slot IS NOT INITIAL.
      " read from t_arg (the unchanged importing parameter), never from lt_arg
      " which is the assignment target here - referencing the target inside its
      " own VALUE constructor reads it while it is being rebuilt in place
      DATA temp1029 TYPE string_table.
      CLEAR temp1029.
      DATA temp35 TYPE string.
      CLEAR temp35.
      DATA temp36 TYPE string.
      READ TABLE t_arg INTO temp36 INDEX 1.
      IF sy-subrc = 0.
        temp35 = temp36.
      ENDIF.
      INSERT temp35 INTO TABLE temp1029.
      INSERT lv_slot INTO TABLE temp1029.
      INSERT `to` INTO TABLE temp1029.
      DATA temp37 TYPE string.
      CLEAR temp37.
      DATA temp38 TYPE string.
      READ TABLE t_arg INTO temp38 INDEX 2.
      IF sy-subrc = 0.
        temp37 = temp38.
      ENDIF.
      INSERT temp37 INTO TABLE temp1029.
      lt_arg = temp1029.
      lv_val = z2ui5_if_client=>cs_event-control_by_id.
    ELSEIF lv_val = z2ui5_if_client=>cs_event-control_by_id.
      " the view is passed as its own parameter now, not as a positional
      " t_arg slot; inject it at position 2 so the frontend still reads
      " args = id, view, method, ... . cs_view-main maps to the empty slot,
      " keeping the unchanged default where the id resolves across all open
      " views (resolveById); a concrete view scopes the lookup to that slot.
      DATA temp1031 TYPE string.
      temp1031 = view.
      DATA temp39 TYPE string.
      IF view = z2ui5_if_client=>cs_view-main.
        temp39 = ``.
      ELSE.
        temp39 = temp1031.
      ENDIF.
      DATA lv_view_slot LIKE temp39.
      lv_view_slot = temp39.
      " lt_arg already equals t_arg (set at the top); this branch did not
      " touch it, so inject the view slot directly.
      INSERT lv_view_slot INTO lt_arg INDEX 2.
    ELSEIF lv_val = z2ui5_if_client=>cs_event-bind_element.
      " element-bind a whole view slot to a table row: args = slot, index,
      " path. The path comes from client->_bind( table ); _bind returns the
      " binding with braces ({/MT_TAB}), which would be an invalid raw JS
      " argument, so strip the braces here to a plain path ('/MT_TAB') that
      " get_t_arg then quotes. The slot is the follow_up_action view parameter.
      DATA temp1032 TYPE string.
      CLEAR temp1032.
      DATA temp1033 TYPE string.
      READ TABLE t_arg INTO temp1033 INDEX 2.
      IF sy-subrc = 0.
        temp1032 = temp1033.
      ENDIF.
      DATA temp40 TYPE string.
      temp40 = temp1032.
      DATA lv_bind_path LIKE temp40.
      lv_bind_path = temp40.
      REPLACE ALL OCCURRENCES OF `{` IN lv_bind_path WITH ``.
      REPLACE ALL OCCURRENCES OF `}` IN lv_bind_path WITH ``.
      DATA temp1034 TYPE string_table.
      CLEAR temp1034.
      DATA temp41 TYPE string.
      temp41 = view.
      INSERT temp41 INTO TABLE temp1034.
      DATA temp42 TYPE string.
      CLEAR temp42.
      DATA temp43 TYPE string.
      READ TABLE t_arg INTO temp43 INDEX 1.
      IF sy-subrc = 0.
        temp42 = temp43.
      ENDIF.
      INSERT temp42 INTO TABLE temp1034.
      INSERT lv_bind_path INTO TABLE temp1034.
      lt_arg = temp1034.
    ENDIF.

    result = |{ z2ui5_if_core_types=>cs_ui5-event_frontend_function }('{ lv_val }'{ get_t_arg( lt_arg ) }|.

  ENDMETHOD.

  METHOD get_t_arg.

    DATA lv_new TYPE string.
    DATA lv_pending TYPE string.
    DATA temp1036 LIKE LINE OF val.
    DATA lr_arg LIKE REF TO temp1036.
    LOOP AT val REFERENCE INTO lr_arg.

      lv_new = lr_arg->*.
      IF lv_new IS INITIAL.
        " an empty argument between filled ones must keep its position -
        " dropping it would shift every following argument into the wrong
        " slot (a CONTROL_BY_ID action without a view lost its method name
        " this way). Buffer it and only flush when a later non-empty
        " argument follows, so trailing empties still disappear.
        lv_pending = |{ lv_pending }, ''|.
        CONTINUE.
      ENDIF.
      " a message template that starts with a bare positional placeholder
      " ({0}, {1}, ... - either immediately closed {0} or a conditional
      " {0?a:b}) is a plain string, not a binding or object literal, so it must
      " still be quoted - the `{`-raw exception below is only for real
      " bindings/object literals like {/PATH} or {..}. {0/field} (relative
      " binding) keeps a `/` after the digits and is therefore not matched, so
      " it stays raw as before.
      FIND REGEX `^\{[0-9]+[?}]` IN lv_new.
      DATA lv_is_placeholder TYPE abap_bool.
      DATA temp27 TYPE xsdboolean.
      temp27 = boolc( sy-subrc = 0 ).
      lv_is_placeholder = temp27.
      IF ( lv_new(1) <> `$` AND lv_new(1) <> `{` AND lv_new NP `.eB(*` ) OR lv_is_placeholder = abap_true.
        " a quoted arg is JS string source (a backslash escape like \n stays a
        " newline); escape only an embedded ' so it cannot close the '...'
        " wrapper - otherwise a template like Value changed to '{0}' emits
        " broken JS.
        REPLACE ALL OCCURRENCES OF `'` IN lv_new WITH `\'`.
        lv_new = |'{ lv_new }'|.
      ENDIF.
      result = |{ result }{ lv_pending }, { lv_new }|.
      lv_pending = ``.
    ENDLOOP.

    result = |{ result })|.

  ENDMETHOD.

ENDCLASS.

CLASS z2ui5_cl_core_srv_draft IMPLEMENTATION.

