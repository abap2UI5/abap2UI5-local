      DATA temp20 LIKE sy-tabix.
      temp20 = sy-tabix.
      READ TABLE lt_mapping WITH KEY n = lr_row->option INTO temp19.
      sy-tabix = temp20.
      IF sy-subrc <> 0.
        ASSERT 1 = 0.
      ENDIF.
      lv_value = temp19-v.
      REPLACE `{LOW}`  IN lv_value WITH lr_row->low.
      REPLACE `{HIGH}` IN lv_value WITH lr_row->high.

      DATA temp823 TYPE z2ui5_cl_util=>ty_s_token.
