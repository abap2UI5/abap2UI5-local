  METHOD factory.

    result = NEW #( ).

    result->mt_prop = t_ns.

    result->mt_prop   = VALUE #( BASE result->mt_prop
                                 (  n = `displayBlock`   v = `true` )
                                 (  n = `height`         v = `100%` ) ).

    result->mv_name   = `View`.
    result->mv_ns     = `mvc`.
    result->mo_root   = result.
    result->mo_parent = result.

    INSERT VALUE #( n = `xmlns`
