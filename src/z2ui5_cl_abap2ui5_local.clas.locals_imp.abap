  METHOD parse.

    DATA lo_parser TYPE REF TO kHGwlzUrcuWxYGvxpUmmfipvepHQnc.

    CREATE OBJECT ro_instance.
    CREATE OBJECT lo_parser.
    ro_instance->mt_json_tree = lo_parser->parse(
      iv_json            = iv_json
      iv_keep_item_order = iv_keep_item_order ).
