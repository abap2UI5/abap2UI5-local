    CLEAR temp744.
    temp744-type = `E`.
    temp744-text = val.
    INSERT temp744 INTO TABLE mt_log.
    result = me.

  ENDMETHOD.

  METHOD warning.

    DATA temp745 TYPE z2ui5_cl_util=>ty_s_msg.
    CLEAR temp745.
    temp745-type = `W`.
    temp745-text = val.
    INSERT temp745 INTO TABLE mt_log.
    result = me.

  ENDMETHOD.

  METHOD success.

    DATA temp746 TYPE z2ui5_cl_util=>ty_s_msg.
    CLEAR temp746.
    temp746-type = `S`.
    temp746-text = val.
    INSERT temp746 INTO TABLE mt_log.
    result = me.

  ENDMETHOD.

  METHOD clear.

    CLEAR mt_log.
    result = me.

  ENDMETHOD.

  METHOD has_error.

    DATA temp747 LIKE sy-subrc.
    READ TABLE mt_log WITH KEY type = `E` TRANSPORTING NO FIELDS.
    temp747 = sy-subrc.
    DATA temp2 TYPE xsdboolean.
    temp2 = boolc( temp747 = 0 ).
    result = temp2.

  ENDMETHOD.

  METHOD count.

    result = lines( mt_log ).

  ENDMETHOD.

  METHOD bal_read.

    DATA lt_msg TYPE z2ui5_cl_util=>ty_t_msg.
    lt_msg = z2ui5_cl_util_ext=>bal_read(
         object    = object
         subobject = subobject
         id        = id ).
    INSERT LINES OF lt_msg INTO TABLE mt_log.

  ENDMETHOD.

  METHOD bal_save.

    z2ui5_cl_util_ext=>bal_create(
        object    = object
        subobject = subobject
        id        = id
        t_log     = mt_log ).

  ENDMETHOD.

  METHOD to_csv.

    result = z2ui5_cl_util=>itab_get_csv_by_itab( mt_log ).

  ENDMETHOD.

  METHOD to_xlsx.

    result = z2ui5_cl_util_ext=>conv_get_xlsx_by_itab( mt_log ).

  ENDMETHOD.

  METHOD to_msg.

    result = mt_log.

  ENDMETHOD.

  METHOD to_string.

    DATA ls_msg LIKE LINE OF mt_log.
    LOOP AT mt_log INTO ls_msg.
      IF result IS NOT INITIAL.
