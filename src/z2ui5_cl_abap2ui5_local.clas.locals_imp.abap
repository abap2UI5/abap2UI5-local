  METHOD filter_get_multi_by_data.

    DATA temp815 TYPE abap_component_tab.
    temp815 = rtti_get_t_attri_by_any( val ).
    DATA temp16 LIKE LINE OF temp815.
    DATA lr_comp LIKE REF TO temp16.
    LOOP AT temp815 REFERENCE INTO lr_comp.
      DATA temp816 TYPE z2ui5_cl_util=>ty_s_filter_multi.
