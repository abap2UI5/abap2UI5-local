  METHOD get.

    IF name IS INITIAL.
      result = mo_root->mo_previous.
      RETURN.
    ENDIF.

    IF mo_parent->mv_name = name.
      result = mo_parent.
    ELSEIF mo_parent <> me.
      " walk up the tree; stop at the root, whose mo_parent points to itself
      " (set in factory) - recursing there would loop forever on a name that
      " matches no ancestor. A name not found leaves result unbound.
      result = mo_parent->get( name ).
    ENDIF.

  ENDMETHOD.

  METHOD get_child.
    DATA temp220 LIKE LINE OF mt_child.
    DATA temp221 LIKE sy-tabix.
    temp221 = sy-tabix.
    READ TABLE mt_child INDEX index INTO temp220.
    sy-tabix = temp221.
    IF sy-subrc <> 0.
      ASSERT 1 = 0.
    ENDIF.
    result = temp220.
  ENDMETHOD.

