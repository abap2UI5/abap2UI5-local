    LOOP AT lt_comps REFERENCE INTO lr_comp.
      ASSIGN COMPONENT lr_comp->name OF STRUCTURE old TO <old_field>.
      IF sy-subrc <> 0.
        CONTINUE.
      ENDIF.
      ASSIGN COMPONENT lr_comp->name OF STRUCTURE new TO <new_field>.
      IF sy-subrc <> 0.
        CONTINUE.
      ENDIF.
      IF <old_field> <> <new_field>.
        DATA temp926 TYPE z2ui5_cl_util=>ty_s_field_diff.
        CLEAR temp926.
        temp926-fieldname = lr_comp->name.
        temp926-old_value = |{ <old_field> }|.
        temp926-new_value = |{ <new_field> }|.
        INSERT temp926 INTO TABLE result.
      ENDIF.
    ENDLOOP.

  ENDMETHOD.

