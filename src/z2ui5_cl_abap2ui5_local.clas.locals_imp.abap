  METHOD ui5_msg_box_format.

    DATA lt_msg TYPE z2ui5_cl_a2ui5_context=>ty_t_msg.
    lt_msg = msg_get_t( val ).

    IF lines( lt_msg ) = 1.
      DATA temp1118 LIKE LINE OF lt_msg.
      DATA temp1119 LIKE sy-tabix.
      temp1119 = sy-tabix.
      READ TABLE lt_msg INDEX 1 INTO temp1118.
      sy-tabix = temp1119.
      IF sy-subrc <> 0.
        ASSERT 1 = 0.
      ENDIF.
      result-text  = temp1118-text.
      DATA temp1120 LIKE LINE OF lt_msg.
      DATA temp1121 LIKE sy-tabix.
      temp1121 = sy-tabix.
      READ TABLE lt_msg INDEX 1 INTO temp1120.
      sy-tabix = temp1121.
      IF sy-subrc <> 0.
        ASSERT 1 = 0.
      ENDIF.
      result-type  = to_lower( ui5_get_msg_type( temp1120-type ) ).
      DATA temp1122 LIKE LINE OF lt_msg.
      DATA temp1123 LIKE sy-tabix.
      temp1123 = sy-tabix.
      READ TABLE lt_msg INDEX 1 INTO temp1122.
      sy-tabix = temp1123.
      IF sy-subrc <> 0.
        ASSERT 1 = 0.
      ENDIF.
      result-title = ui5_get_msg_type( temp1122-type ).

    ELSEIF lines( lt_msg ) > 1.
      result-text = | { lines( lt_msg ) } Messages found: |.
      DATA lt_detail_items TYPE string_table.
      DATA temp1124 LIKE LINE OF lt_msg.
      DATA lr_msg LIKE REF TO temp1124.
      LOOP AT lt_msg REFERENCE INTO lr_msg.
        DATA temp1125 LIKE LINE OF lt_detail_items.
        temp1125 = |<li>{ lr_msg->text }</li>|.
        INSERT temp1125 INTO TABLE lt_detail_items.
      ENDLOOP.
      result-details = `<ul>` && concat_lines_of( lt_detail_items ) && `</ul>`.
      DATA temp1126 LIKE LINE OF lt_msg.
      DATA temp1127 LIKE sy-tabix.
      temp1127 = sy-tabix.
      READ TABLE lt_msg INDEX 1 INTO temp1126.
      sy-tabix = temp1127.
      IF sy-subrc <> 0.
        ASSERT 1 = 0.
      ENDIF.
      result-title   = ui5_get_msg_type( temp1126-type ).
      DATA temp1128 LIKE LINE OF lt_msg.
      DATA temp1129 LIKE sy-tabix.
      temp1129 = sy-tabix.
      READ TABLE lt_msg INDEX 1 INTO temp1128.
      sy-tabix = temp1129.
      IF sy-subrc <> 0.
        ASSERT 1 = 0.
      ENDIF.
      result-type    = ui5_get_msg_type( temp1128-type ).

    ELSE.
      result-skip = abap_true.
    ENDIF.

  ENDMETHOD.

