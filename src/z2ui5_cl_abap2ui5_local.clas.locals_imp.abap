             `        key: "NEST2",` && |\n| &&
             `        param: "S_VIEW_NEST2",` && |\n| &&
             `        prop: "oViewNest2",` && |\n| &&
             `        controllerProp: "oControllerNest2",` && |\n| &&
             `      },` && |\n| &&
             `      {` && |\n| &&
             `        key: "POPUP",` && |\n| &&
             `        param: "S_POPUP",` && |\n| &&
             `        prop: "oViewPopup",` && |\n| &&
             `        controllerProp: "oControllerPopup",` && |\n| &&
             `        fragmentId: "popupId",` && |\n| &&
