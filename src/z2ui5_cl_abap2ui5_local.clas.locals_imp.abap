  METHOD msg_get_text.

    DATA lt_msg TYPE z2ui5_cl_util=>ty_t_msg.
    lt_msg = msg_get_t( val = val val2 = val2 ).
    IF lt_msg IS NOT INITIAL.
      DATA temp935 LIKE LINE OF lt_msg.
      DATA temp936 LIKE sy-tabix.
      temp936 = sy-tabix.
      READ TABLE lt_msg INDEX 1 INTO temp935.
      sy-tabix = temp936.
      IF sy-subrc <> 0.
        ASSERT 1 = 0.
      ENDIF.
      result = temp935-text.
    ENDIF.

  ENDMETHOD.

