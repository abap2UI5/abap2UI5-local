  METHOD itab_count_by.

    FIELD-SYMBOLS <row>   TYPE any.
    FIELD-SYMBOLS <field> TYPE any.

    LOOP AT tab ASSIGNING <row>.
      ASSIGN COMPONENT fieldname OF STRUCTURE <row> TO <field>.
      IF sy-subrc <> 0.
        CONTINUE.
      ENDIF.
      DATA lv_val TYPE string.
      lv_val = |{ <field> }|.
      FIELD-SYMBOLS <entry> TYPE z2ui5_cl_util=>ty_s_name_value.
      READ TABLE result ASSIGNING <entry> WITH KEY n = lv_val.
      IF sy-subrc = 0.
        DATA temp918 TYPE i.
        temp918 = <entry>-v.
        DATA lv_count TYPE i.
        lv_count = temp918 + 1.
        <entry>-v = |{ lv_count }|.
      ELSE.
        DATA temp919 TYPE z2ui5_cl_util=>ty_s_name_value.
        CLEAR temp919.
        temp919-n = lv_val.
        temp919-v = `1`.
        INSERT temp919 INTO TABLE result.
      ENDIF.
    ENDLOOP.

  ENDMETHOD.

  " ========== Validation Helpers ==========

  METHOD check_is_email.

    DATA temp920 TYPE string.
    temp920 = val.
    DATA lv_val TYPE string.
    lv_val = c_trim( temp920 ).

    IF lv_val IS INITIAL.
      result = abap_false.
      RETURN.
    ENDIF.

    " Basic email validation: contains exactly one @, has text before and after,
    " domain part contains at least one dot
    DATA lv_local TYPE string.
    DATA lv_domain TYPE string.
    DATA lv_extra TYPE string.
    SPLIT lv_val AT `@` INTO lv_local lv_domain lv_extra.
    IF lv_extra IS NOT INITIAL OR lv_local IS INITIAL OR lv_domain IS INITIAL.
      result = abap_false.
      RETURN.
    ENDIF.

    IF lv_domain NA `.`.
      result = abap_false.
      RETURN.
    ENDIF.

    result = abap_true.

  ENDMETHOD.

  METHOD check_is_numeric_string.

    DATA temp921 TYPE string.
    temp921 = val.
    DATA lv_val TYPE string.
    lv_val = c_trim( temp921 ).

    IF lv_val IS INITIAL.
      result = abap_false.
      RETURN.
    ENDIF.

    DATA lv_i TYPE i.
    lv_i = 0.
    DATA lv_has_dot LIKE abap_false.
    lv_has_dot = abap_false.
    WHILE lv_i < strlen( lv_val ).
      DATA lv_c TYPE string.
      lv_c = lv_val+lv_i(1).
      IF lv_c >= `0` AND lv_c <= `9`.
        " digit ok
      ELSEIF lv_c = `-` AND lv_i = 0.
        " leading minus ok
      ELSEIF lv_c = `+` AND lv_i = 0.
        " leading plus ok
      ELSEIF ( lv_c = `.` OR lv_c = `,` ) AND lv_has_dot = abap_false.
        lv_has_dot = abap_true.
      ELSE.
        result = abap_false.
        RETURN.
      ENDIF.
      lv_i = lv_i + 1.
    ENDWHILE.

    result = abap_true.

  ENDMETHOD.

  METHOD check_is_date_valid.

    TRY.
        DATA lv_date TYPE d.
        lv_date = conv_string_to_date( val = val format = format ).
        " Check the date is actually valid (not 00000000 and not invalid like Feb 30)
        IF lv_date IS INITIAL.
          result = abap_false.
          RETURN.
        ENDIF.
        " ABAP validates dates on assignment — if it passed conv_string_to_date it's valid
        DATA temp922 TYPE string.
        temp922 = lv_date.
        DATA lv_check LIKE temp922.
        lv_check = temp922.
        DATA temp19 TYPE xsdboolean.
        temp19 = boolc( lv_check <> `00000000` ).
        result = temp19.
      CATCH cx_root.
        result = abap_false.
    ENDTRY.

  ENDMETHOD.

  METHOD check_is_guid.

    DATA temp923 TYPE string.
    temp923 = val.
    DATA lv_val TYPE string.
    lv_val = c_trim( temp923 ).
    DATA lv_clean TYPE string.
    lv_clean = c_replace_all( val = lv_val sub = `-` new_val = `` ).
    DATA lv_len TYPE i.
    lv_len = strlen( lv_clean ).

    " Accept 32 chars (raw) or 36 chars (with dashes)
    IF lv_len <> 32.
      result = abap_false.
      RETURN.
    ENDIF.

    " All characters must be hex digits
    DATA lv_upper TYPE string.
    lv_upper = to_upper( lv_clean ).
    DATA lv_i TYPE i.
    lv_i = 0.
    WHILE lv_i < 32.
      DATA lv_c TYPE string.
      lv_c = lv_upper+lv_i(1).
      IF NOT ( ( lv_c >= `0` AND lv_c <= `9` ) OR ( lv_c >= `A` AND lv_c <= `F` ) ).
        result = abap_false.
        RETURN.
      ENDIF.
      lv_i = lv_i + 1.
    ENDWHILE.

    result = abap_true.

  ENDMETHOD.

  METHOD check_max_length.

    DATA temp924 TYPE string.
    temp924 = val.
    DATA lv_val LIKE temp924.
    lv_val = temp924.
    DATA temp20 TYPE xsdboolean.
    temp20 = boolc( strlen( lv_val ) <= max ).
    result = temp20.

  ENDMETHOD.

