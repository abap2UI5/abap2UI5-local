                             items  = client->_bind_edit( mt_filter )
                )->custom_list_item( ).

    DATA grid TYPE REF TO z2ui5_cl_xml_view.
    grid = item->grid( ).

    DATA temp978 TYPE string_table.
    CLEAR temp978.
    INSERT `${KEY}` INTO TABLE temp978.
    grid->combobox( selectedkey = `{OPTION}`
                    items       = client->_bind( mt_mapping )
             )->item( key  = `{N}`
                      text = `{N}`
             )->get_parent(
             )->input( value  = `{LOW}`
                       submit = client->_event( `BUTTON_CONFIRM` )
             )->input( value   = `{HIGH}`
                       visible = `{= ${OPTION} === 'BT' }`
                       submit  = client->_event( `BUTTON_CONFIRM` )
             )->button( icon  = `sap-icon://decline`
                        type  = `Transparent`
                        press = client->_event( val   = `POPUP_DELETE`
                                                t_arg = temp978 ) ).

    lo_popup->buttons(
        )->button( text  = `Delete All`
                   icon  = `sap-icon://delete`
                   type  = `Transparent`
                   press = client->_event( `POPUP_DELETE_ALL` )
        )->button( text  = `Add Item`
                   icon  = `sap-icon://add`
                   press = client->_event( `POPUP_ADD` )
       )->button( text  = `Cancel`
                  press = client->_event( `BUTTON_CANCEL` )
       )->button( text  = `OK`
                  press = client->_event( `BUTTON_CONFIRM` )
                  type  = `Emphasized` ).

    client->popup_display( lo_popup->stringify( ) ).

  ENDMETHOD.

  METHOD z2ui5_if_app~main.

    me->client = client.

    IF client->check_on_init( ) IS NOT INITIAL.
      mt_mapping = z2ui5_cl_a2ui5_context=>filter_get_token_range_mapping( ).

      CLEAR mt_filter.
      DATA temp980 LIKE LINE OF ms_result-t_range.
      DATA lr_range LIKE REF TO temp980.
      LOOP AT ms_result-t_range REFERENCE INTO lr_range.
        DATA temp981 TYPE z2ui5_cl_pop_get_range=>ty_s_filter_pop.
        CLEAR temp981.
        temp981-low = lr_range->low.
        temp981-high = lr_range->high.
        temp981-option = lr_range->option.
        temp981-key = z2ui5_cl_a2ui5_context=>uuid_get_c32( ).
        INSERT temp981 INTO TABLE mt_filter.
      ENDLOOP.

      view_display( ).
      RETURN.
    ENDIF.

    CASE client->get( )-event.

      WHEN `BUTTON_CONFIRM`.

        CLEAR ms_result-t_range.
        DATA temp982 LIKE LINE OF mt_filter.
        DATA lr_filter LIKE REF TO temp982.
        LOOP AT mt_filter REFERENCE INTO lr_filter.
          IF lr_filter->low IS INITIAL AND lr_filter->high IS INITIAL.
            CONTINUE.
          ENDIF.
          DATA temp983 TYPE z2ui5_cl_a2ui5_context=>ty_s_range.
          CLEAR temp983.
          temp983-sign = `I`.
          temp983-option = lr_filter->option.
          temp983-low = lr_filter->low.
          temp983-high = lr_filter->high.
          INSERT temp983 INTO TABLE ms_result-t_range.
        ENDLOOP.

        ms_result-check_confirmed = abap_true.
        client->popup_destroy( ).
        client->nav_app_leave( ).

      WHEN `BUTTON_CANCEL`.
        client->popup_destroy( ).
        client->nav_app_leave( ).

      WHEN `POPUP_ADD`.
        DATA temp984 TYPE z2ui5_cl_pop_get_range=>ty_s_filter_pop.
        CLEAR temp984.
        temp984-key = z2ui5_cl_a2ui5_context=>uuid_get_c32( ).
        INSERT temp984 INTO TABLE mt_filter.
        client->popup_model_update( ).

      WHEN `POPUP_DELETE`.
        DELETE mt_filter WHERE key = client->get_event_arg( 1 ).
        client->popup_model_update( ).

      WHEN `POPUP_DELETE_ALL`.
        CLEAR mt_filter.
        client->popup_model_update( ).

    ENDCASE.

  ENDMETHOD.

ENDCLASS.

