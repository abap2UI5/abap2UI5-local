  METHOD url_param_get_tab.

    DATA lv_search TYPE string.
    lv_search = replace( val  = i_val
                               sub  = `%3D`
                               with = `=`
                               occ  = 0 ).

    lv_search = replace( val  = lv_search
                         sub  = `%26`
                         with = `&`
                         occ  = 0 ).

    lv_search = shift_left( val = lv_search
                            sub = `?` ).

    DATA lv_search2 TYPE string.
    lv_search2 = substring_after( val = lv_search
                                        sub = `&sap-startup-params=` ).
    DATA temp853 TYPE string.
    IF lv_search2 IS NOT INITIAL.
      temp853 = lv_search2.
    ELSE.
      temp853 = lv_search.
    ENDIF.
    lv_search = temp853.

    lv_search2 = substring_after( val = c_trim_lower( lv_search )
                                  sub = `?` ).
    IF lv_search2 IS NOT INITIAL.
      lv_search = lv_search2.
    ENDIF.

    TYPES temp28 TYPE STANDARD TABLE OF string WITH DEFAULT KEY.
DATA lt_param TYPE temp28.
    SPLIT lv_search AT `&` INTO TABLE lt_param.

    DATA temp854 LIKE LINE OF lt_param.
    DATA lr_param LIKE REF TO temp854.
    LOOP AT lt_param REFERENCE INTO lr_param.
      DATA lv_name TYPE string.
      DATA lv_value TYPE string.
      SPLIT lr_param->* AT `=` INTO lv_name lv_value.
      DATA temp855 TYPE z2ui5_cl_util=>ty_s_name_value.
      CLEAR temp855.
      temp855-n = lv_name.
      temp855-v = lv_value.
      INSERT temp855 INTO TABLE rt_params.
    ENDLOOP.

  ENDMETHOD.

