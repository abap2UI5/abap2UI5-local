             `    // Controller instance serving a slot (created once in App.controller).` && |\n| &&
             `    function getController(key) {` && |\n| &&
             `      const slot = byKey(key);` && |\n| &&
             `      return slot ? AppState.state[slot.controllerProp] : undefined;` && |\n| &&
             `    }` && |\n| &&
