  METHOD itab_filter_by_val.
    " TRANSPILER NOTE: ABAP CS operator is ALWAYS case-insensitive regardless
    " of the ignore_case flag. The flag only pre-converts to uppercase for
    " consistency, but CS itself never does case-sensitive matching.
    " JS equivalent: always use toLowerCase().includes(toLowerCase()).
    FIELD-SYMBOLS <row>   TYPE any.
    FIELD-SYMBOLS <field> TYPE any.

    DATA temp824 TYPE string.
    IF ignore_case = abap_true.
      temp824 = to_upper( val ).
    ELSE.
      temp824 = val.
    ENDIF.
    DATA lv_search LIKE temp824.
    lv_search = temp824.

    LOOP AT tab ASSIGNING <row>.

      DATA lv_check_found LIKE abap_false.
      lv_check_found = abap_false.
      DATA lv_index TYPE i.
      lv_index = 1.
      DO.
        IF fields IS INITIAL.
          ASSIGN COMPONENT lv_index OF STRUCTURE <row> TO <field>.
          IF sy-subrc <> 0.
            EXIT.
          ENDIF.
        ELSE.
          IF lv_index > lines( fields ).
            EXIT.
          ENDIF.
          DATA lv_name LIKE LINE OF fields.
          DATA temp21 LIKE LINE OF fields.
          DATA temp22 LIKE sy-tabix.
          temp22 = sy-tabix.
          READ TABLE fields INDEX lv_index INTO temp21.
          sy-tabix = temp22.
          IF sy-subrc <> 0.
            ASSERT 1 = 0.
          ENDIF.
          lv_name = temp21.
          ASSIGN COMPONENT lv_name OF STRUCTURE <row> TO <field>.
          IF sy-subrc <> 0.
            lv_index = lv_index + 1.
            CONTINUE.
          ENDIF.
        ENDIF.

        DATA lv_value TYPE string.
        lv_value = |{ <field> }|.
        IF ignore_case = abap_true.
          lv_value = to_upper( lv_value ).
          IF lv_value CS lv_search.
            lv_check_found = abap_true.
            EXIT.
          ENDIF.
        ELSE.
          " Case-sensitive: use find() because CS is always case-insensitive
          IF find( val = lv_value sub = lv_search ) >= 0.
            lv_check_found = abap_true.
            EXIT.
          ENDIF.
        ENDIF.

        lv_index = lv_index + 1.
      ENDDO.

      IF lv_check_found = abap_false.
        DELETE tab.
      ENDIF.

    ENDLOOP.

  ENDMETHOD.

  METHOD itab_get_csv_by_itab.

    FIELD-SYMBOLS <tab> TYPE table.
    DATA lt_lines TYPE string_table.
    DATA lv_line TYPE string.

    ASSIGN val TO <tab>.
    DATA temp825 TYPE REF TO cl_abap_tabledescr.
    temp825 ?= cl_abap_typedescr=>describe_by_data( <tab> ).
    DATA tab LIKE temp825.
    tab = temp825.

    DATA temp826 TYPE REF TO cl_abap_structdescr.
    temp826 ?= tab->get_table_line_type( ).
    DATA struc LIKE temp826.
    struc = temp826.

    CLEAR lv_line.
    DATA temp827 TYPE abap_component_tab.
    temp827 = struc->get_components( ).
    DATA temp23 LIKE LINE OF temp827.
    DATA lr_comp LIKE REF TO temp23.
    LOOP AT temp827 REFERENCE INTO lr_comp.
      lv_line = |{ lv_line }{ lr_comp->name };|.
    ENDLOOP.
    INSERT lv_line INTO TABLE lt_lines.

    DATA lr_row TYPE REF TO data.
    LOOP AT <tab> REFERENCE INTO lr_row.

      CLEAR lv_line.
      DATA lv_index TYPE i.
      lv_index = 1.
      DO.
        FIELD-SYMBOLS <row> TYPE data.
        ASSIGN lr_row->* TO <row>.
        FIELD-SYMBOLS <field> TYPE any.
        ASSIGN COMPONENT lv_index OF STRUCTURE <row> TO <field>.
        IF sy-subrc <> 0.
          EXIT.
        ENDIF.
        lv_index = lv_index + 1.
        DATA lv_field_val TYPE string.
        lv_field_val = |{ <field> }|.
        REPLACE ALL OCCURRENCES OF `;` IN lv_field_val WITH `,`.
        lv_line = |{ lv_line }{ lv_field_val };|.
      ENDDO.
      INSERT lv_line INTO TABLE lt_lines.
    ENDLOOP.

    result = concat_lines_of( table = lt_lines sep = cv_char_util_cr_lf ).

  ENDMETHOD.

  METHOD itab_get_itab_by_csv.

    DATA lt_comp TYPE cl_abap_structdescr=>component_table.
    FIELD-SYMBOLS <tab> TYPE STANDARD TABLE.
    DATA lr_row TYPE REF TO data.

    TYPES temp26 TYPE STANDARD TABLE OF string WITH DEFAULT KEY.
DATA lt_rows TYPE temp26.
    SPLIT val AT cv_char_util_newline INTO TABLE lt_rows.
    TYPES temp27 TYPE STANDARD TABLE OF string WITH DEFAULT KEY.
DATA lt_cols TYPE temp27.
    DATA temp24 LIKE LINE OF lt_rows.
    DATA temp25 LIKE sy-tabix.
    temp25 = sy-tabix.
    READ TABLE lt_rows INDEX 1 INTO temp24.
    sy-tabix = temp25.
    IF sy-subrc <> 0.
      ASSERT 1 = 0.
    ENDIF.
    SPLIT temp24 AT `;` INTO TABLE lt_cols.

    DATA temp828 LIKE LINE OF lt_cols.
    DATA lr_col LIKE REF TO temp828.
    LOOP AT lt_cols REFERENCE INTO lr_col.

      DATA lv_name TYPE string.
      lv_name = c_trim_upper( lr_col->* ).
      REPLACE ALL OCCURRENCES OF ` ` IN lv_name WITH `_`.

      DATA temp829 TYPE abap_componentdescr.
      CLEAR temp829.
      temp829-name = lv_name.
      temp829-type = cl_abap_elemdescr=>get_c( 40 ).
      INSERT temp829 INTO TABLE lt_comp.
    ENDLOOP.

    DATA struc TYPE REF TO cl_abap_structdescr.
    struc = cl_abap_structdescr=>get( lt_comp ).
    DATA temp830 TYPE REF TO cl_abap_datadescr.
    temp830 ?= struc.
    DATA data LIKE temp830.
    data = temp830.
    DATA o_table_desc TYPE REF TO cl_abap_tabledescr.
    o_table_desc = cl_abap_tabledescr=>create( p_line_type  = data
                                                     p_table_kind = cl_abap_tabledescr=>tablekind_std
                                                     p_unique     = abap_false ).

    CREATE DATA result TYPE HANDLE o_table_desc.
    ASSIGN result->* TO <tab>.
    DELETE lt_rows WHERE table_line IS INITIAL.

    DATA temp831 LIKE LINE OF lt_rows.
    DATA lr_rows LIKE REF TO temp831.
    LOOP AT lt_rows REFERENCE INTO lr_rows FROM 2.

      SPLIT lr_rows->* AT `;` INTO TABLE lt_cols.
      CREATE DATA lr_row TYPE HANDLE struc.

      LOOP AT lt_cols REFERENCE INTO lr_col.
        FIELD-SYMBOLS <row> TYPE data.
        ASSIGN lr_row->* TO <row>.
        FIELD-SYMBOLS <field> TYPE any.
        ASSIGN COMPONENT sy-tabix OF STRUCTURE <row> TO <field>.
        IF sy-subrc <> 0.
          EXIT.
        ENDIF.
        <field> = lr_col->*.
      ENDLOOP.

      INSERT <row> INTO TABLE <tab>.
    ENDLOOP.

  ENDMETHOD.

