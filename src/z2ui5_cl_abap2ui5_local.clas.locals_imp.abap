        IF ls_filter-t_range IS INITIAL.
          CONTINUE.
        ENDIF.

        FIELD-SYMBOLS <field> TYPE any.
        ASSIGN ref->(ls_filter-name) TO <field>.
        IF sy-subrc <> 0.
          CONTINUE.
