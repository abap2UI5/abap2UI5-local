CLASS z2ui5_cx_util_error IMPLEMENTATION.
  METHOD constructor ##ADT_SUPPRESS_GENERATION.

    super->constructor( previous = previous ).
    CLEAR textid.

    TRY.
        ms_error-x_root ?= val.
      CATCH cx_root.
        ms_error-text = val.
    ENDTRY.
    ms_error-uuid = z2ui5_cl_util=>uuid_get_c32( ).

  ENDMETHOD.

  METHOD if_message~get_text.

    IF ms_error-x_root IS NOT INITIAL.
      result = ms_error-x_root->get_text( ).

      DATA error LIKE abap_true.
      error = abap_true.
    ELSEIF ms_error-text IS NOT INITIAL.
      result = ms_error-text.
      error = abap_true.
    ENDIF.

    IF previous IS BOUND.
      DATA lo_x LIKE previous.
      lo_x = previous.
      WHILE lo_x IS BOUND.
        result = result && z2ui5_cl_util=>cv_char_util_newline && lo_x->get_text( ).
        lo_x = lo_x->previous.
      ENDWHILE.
    ENDIF.
    DATA temp1 TYPE string.
    IF error = abap_true AND result IS INITIAL.
      temp1 = `UNKNOWN_ERROR`.
    ELSE.
      temp1 = result.
    ENDIF.
    result = temp1.

  ENDMETHOD.
ENDCLASS.

CLASS z2ui5_cx_srt IMPLEMENTATION.
  METHOD constructor ##ADT_SUPPRESS_GENERATION.
    CALL METHOD super->constructor
